# ============================================================
# Hermes SEO v3 — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- LLM APIs (au moins un requis) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=...        # Optionnel, fallback budget

# --- SERP API (au moins un requis, priorite recommandee) ---
# TalorData : $0.25-0.90/1K, gratuit 1000 req/mois, compatible SerpApi
TALORDATA_API_KEY=...
# Scrape.do : $1.16/1K, 60% AI Overview detection
SCRAPEDO_API_KEY=...
# Serpstack : fallback historique
SERPSTACK_API_KEY=...

# --- Google (optionnel) ---
GSC_CLIENT_ID=...
GSC_CLIENT_SECRET=...
GSC_REFRESH_TOKEN=...

# --- Base de donnees ---
CHROMA_PERSIST_DIRECTORY=./data/chroma
SQLITE_DB_PATH=./data/sqlite/hermes.db

# --- Logs & Sessions ---
LOG_DIRECTORY=./logs
SESSION_DIRECTORY=./sessions
LOG_LEVEL=INFO

# --- Budgets par defaut ---
DEFAULT_TOKEN_BUDGET=1000000
DEFAULT_COST_BUDGET=5.0

# --- Mode par defaut ---
DEFAULT_QUALITY_MODE=standard

# --- Ollama (optionnel, fallback local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama4:latest
